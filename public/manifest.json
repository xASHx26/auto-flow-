{
  "manifest_version": 3,
  "name": "Katalon-Style Recorder Pro",
  "version": "1.3.0",
  "description": "Professional Web Automation Recorder with Grid Editor and Sidebar",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "scripting",
    "alarms",
    "contextMenus",
    "downloads",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Automation Pro Recorder"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
